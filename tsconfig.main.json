{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": [
            "ES2020"
        ],
        "outDir": "dist/main",
        "rootDir": "src/main",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/main/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}