{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "noEmit": true
    },
    "include": [
        "src/renderer/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}